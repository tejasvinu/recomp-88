## MongoDB
# Required for sign-up, profile, and cloud sync
MONGODB_URI=mongodb://127.0.0.1:27017/recomp88

## NextAuth
# Generate a strong secret for production
AUTH_SECRET=replace-me-with-a-long-random-secret

## Google OAuth (optional)
# Needed only if you want "Continue with Google" to work
AUTH_GOOGLE_ID=replace-me.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=replace-me
